{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WangyiMCCheckworld",
  "version": "0.1.3",
  "identifier": "com.vincentzyu.wangyi-mc-checkworld-tauri",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "WangyiMCCheckworld",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "fileName": "wangyi-mc-checkworld-tauri-v${version}-windows-x64",
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
