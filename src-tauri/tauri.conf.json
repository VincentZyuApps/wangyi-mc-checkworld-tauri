{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MC NetEase World Manager",
  "version": "0.1.0",
  "identifier": "com.vincentzyu.mc-netease-world-manager",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
